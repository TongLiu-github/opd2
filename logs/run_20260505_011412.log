[36m(TaskRunner pid=202387)[0m 240 - \frac{540}{s} = 144 - \frac{540}{s + 2}
[36m(TaskRunner pid=202387)[0m $$
[36m(TaskRunner pid=202387)[0m 
[36m(TaskRunner pid=202387)[0m Simplify:
[36m(TaskRunner pid=202387)[0m 
[36m(TaskRunner pid=202387)[0m $$
[36m(TaskRunner pid=202387)[0m 96 = \frac{540}{s} - \frac{540}{s + 2}
[36m(TaskRunner pid=202387)[0m $$
[36m(TaskRunner pid=202387)[0m 
[36m(TaskRunner pid=202387)[0m Factor out 540:
[36m(TaskRunner pid=202387)[0m 
[36m(TaskRunner pid=202387)[0m $$
[36m(TaskRunner pid=202387)[0m 96 = 540 \left( \frac{1}{s} - \frac{1}{s + 2} \right) = 540 \cdot \frac{2}{s(s + 2)}
[36m(TaskRunner pid=202387)[0m $$
[36m(TaskRunner pid=202387)[0m 
[36m(TaskRunner pid=202387)[0m $$
[36m(TaskRunner pid=202387)[0m 96 = \frac{1080}{s(s + 2)}
[36m(TaskRunner pid=202387)[0m $$
[36m(TaskRunner pid=202387)[0m 
[36m(TaskRunner pid=202387)[0m Multiply both sides by $ s(s + 2) $:
[36m(TaskRunner pid=202387)[0m 
[36m(TaskRunner pid=202387)[0m $$
[36m(TaskRunner pid=202387)[0m 96s(s + 2) = 1080
[36m(TaskRunner pid=202387)[0m $$
[36m(TaskRunner pid=202387)[0m 
[36m(TaskRunner pid=202387)[0m Divide both sides by 24:
[36m(TaskRunner pid=202387)[0m 
[36m(TaskRunner pid=202387)[0m $$
[36m(TaskRunner pid=202387)[0m 4s(s + 2) = 45 \Rightarrow 4s^2 + 8s - 45 = 0
[36m(TaskRunner pid=202387)[0m $$
[36m(TaskRunner pid=202387)[0m 
[36m(TaskRunner pid=202387)[0m Solve using the quadratic formula:
[36m(TaskRunner pid=202387)[0m 
[36m(TaskRunner pid=202387)[0m $$
[36m(TaskRunner pid=202387)[0m s = \frac{-8 \pm \sqrt{64 + 720}}{8} = \frac{-8 \pm 28}{8}
[36m(TaskRunner pid=202387)[0m $$
[36m(TaskRunner pid=202387)[0m 
[36m(TaskRunner pid=202387)[0m $$
[36m(TaskRunner pid=202387)[0m s = \frac{20}{8} = 2.5 \quad \text{(valid since speed must be positive)}
[36m(TaskRunner pid=202387)[0m $$
[36m(TaskRunner pid=202387)[0m 
[36m(TaskRunner pid=202387)[0m Now find $ t $ using Equation (1):
[36m(TaskRunner pid=202387)[0m 
[36m(TaskRunner pid=202387)[0m $$
[36m(TaskRunner pid=202387)[0m t = 240 - \frac{540}{2.5} = 240 - 216 = 24 \text{ minutes}
[36m(TaskRunner pid=202387)[0m $$
[36m(TaskRunner pid=202387)[0m 
[36m(TaskRunner pid=202387)[0m ---
[36m(TaskRunner pid=202387)[0m 
[36m(TaskRunner pid=202387)[0m ### Step 4: Find the Time at $ s + \frac{1}{2} $
[36m(TaskRunner pid=202387)[0m 
[36m(TaskRunner pid=202387)[0m We are now to find the total time when Aya walks at $ s + \frac{1}{2} = 2.5 + 0.5 = 3 $ km/h.
[36m(TaskRunner pid=202387)[0m 
[36m(TaskRunner pid=202387)[0m Time spent walking is:
[36m(TaskRunner pid=202387)[0m 
[36m(TaskRunner pid=202387)[0m $$
[36m(TaskRunner pid=202387)[0m \frac{9}{3} = 3 \text{ hours}
[36m(TaskRunner pid=202387)[0m $$
[36m(TaskRunner pid=202387)[0m 
[36m(TaskRunner pid=202387)[0m Convert to minutes:
[36m(TaskRunner pid=202387)[0m 
[36m(TaskRunner pid=202387)[0m $$
[36m(TaskRunner pid=202387)[0m 3 \text{ hours} = 180 \text{ minutes}
[36m(TaskRunner pid=202387)[0m $$
[36m(TaskRunner pid=202387)[0m 
[36m(TaskRunner pid=202387)[0m Add the $ t = 24 $ minutes:
[36m(TaskRunner pid=202387)[0m 
[36m(TaskRunner pid=202387)[0m $$
[36m(TaskRunner pid=202387)[0m 180 + 24 = 204 \text{ minutes}
[36m(TaskRunner pid=202387)[0m $$
[36m(TaskRunner pid=202387)[0m 
